      <div style="display:flex;gap:8px;flex-wrap:wrap">
        <input type="text" placeholder="¿Qué cambiamos?" style="flex:2;min-width:140px;border:.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);padding:7px 10px;font-size:12px;font-family:var(--font-sans);background:var(--color-background-primary);color:var(--color-text-primary)"/>
        <input type="text" placeholder="Responsable" style="flex:1;min-width:90px;border:.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);padding:7px 10px;font-size:12px;font-family:var(--font-sans);background:var(--color-background-primary);color:var(--color-text-primary)"/>
        <input type="text" placeholder="Fecha" style="flex:1;min-width:80px;border:.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);padding:7px 10px;font-size:12px;font-family:var(--font-sans);background:var(--color-background-primary);color:var(--color-text-primary)"/>
      </div>
    </div>
    <div class="cg"><strong>Sprint terminado.</strong> En el plenario: ¿cuál fue la acción de mejora de cada squad? ¿Qué fue lo más incómodo de trabajar así?</div>
  </div>

  <div class="nav">
    <button class="pbtn" onclick="go(4)">← Anterior</button>
    <button class="nbtn" style="background:var(--color-background-success);color:var(--color-text-success)" onclick="go(0)">↺ Volver al inicio</button>
  </div>
</div>
</div>

<script>
const tmrs={};
function go(n){
  document.querySelectorAll('.panel').forEach((p,i)=>p.classList.toggle('on',i===n));
  document.querySelectorAll('.sp').forEach((p,i)=>p.classList.toggle('on',i===n));
  window.scrollTo({top:0,behavior:'smooth'});
}
function startT(id,secs){
  if(tmrs[id]){clearInterval(tmrs[id]);delete tmrs[id];}
  let r=secs;
  const el=document.getElementById('t'+id);
  tmrs[id]=setInterval(()=>{
    if(r<=0){clearInterval(tmrs[id]);el.textContent='00:00';el.classList.add('urg');return;}
    r--;
    const m=Math.floor(r/60),s=r%60;
    el.textContent=String(m).padStart(2,'0')+':'+String(s).padStart(2,'0');
    el.classList.toggle('urg',r<=60);
  },1000);
}
function resetT(id,lbl){
  if(tmrs[id]){clearInterval(tmrs[id]);delete tmrs[id];}
  const el=document.getElementById('t'+id);
  el.textContent=lbl;
  el.classList.remove('urg');
}
document.querySelectorAll('#sbl input[type=text]:last-child').forEach(inp=>{
  inp.addEventListener('input',()=>{
    let t=0;
    document.querySelectorAll('#sbl input[type=text]:last-child').forEach(i=>{
      const v=parseInt(i.value);
      if(!isNaN(v))t+=v;
    });
    document.getElementById('tot').textContent=t;
    document.getElementById('tot').style.color=t>12?'var(--color-text-danger)':t===12?'var(--color-text-success)':'var(--color-text-primary)';
  });
});
</script>
